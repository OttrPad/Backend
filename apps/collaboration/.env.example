# Yjs Collaboration Service Configuration - Phase 1

# WebSocket Server
YJS_WEBSOCKET_PORT=4002

# Room Management (Start small for Phase 1)
YJS_MAX_ROOMS_IN_MEMORY=100
YJS_ROOM_INACTIVE_TIMEOUT=3600000     # 1 hour (in milliseconds)
YJS_USER_INACTIVE_TIMEOUT=300000      # 5 minutes (in milliseconds)
YJS_MAX_USERS_PER_ROOM=50

# Logging
YJS_ENABLE_LOGGING=true

# Note: Supabase configuration is handled by the shared @packages/supabase package
# No need for SUPABASE_URL, SUPABASE_KEY, or SUPABASE_JWT_SECRET here

# Phase 2 Configuration (Not implemented yet)
# YJS_ENABLE_PERSISTENCE=false
# YJS_AUTO_SAVE_INTERVAL=300000
# YJS_ENABLE_REDIS=false
# REDIS_URL=redis://localhost:6379
